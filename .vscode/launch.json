{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Python Debugger",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/fakevine/__init__.py",
            "cwd" : "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "uv_sync",
        },
        {
            "name": "Python Debugger: Utils",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/fakevine/utils/__init__.py",
            "cwd" : "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "uv_sync",
            "args" : ["convert-db","source.db", "output.db", "--overwrite"]
        },
    ]
}