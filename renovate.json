{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:weekly",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigests", 
    ":configMigration", 
    ":pinDevDependencies", 
    "abandonments:recommended",
    ":maintainLockFilesWeekly",
    "group:allDigest"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "packageRules": [{
      "matchManagers": [
        "docker-compose"
      ],
      "matchUpdateTypes": [
        "digest"
      ],
    "enabled": false
  }]
}
